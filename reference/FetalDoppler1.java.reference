        private String getDateTime () {
        DateFormat dateFormat = new SimpleDateFormat("yyyy-MM-dd_HH:mm:ss");
        Date date = new Date();
        return dateFormat.format(date);
    }

        public int getScreenOrientation () {
        Display getOrient = this.getWindowManager().getDefaultDisplay();
        int orientation = Configuration.ORIENTATION_UNDEFINED;
        if (getOrient.getWidth() == getOrient.getHeight()) {
            orientation = Configuration.ORIENTATION_SQUARE;
        } else {
            if (getOrient.getWidth() < getOrient.getHeight()) {
                orientation = Configuration.ORIENTATION_PORTRAIT;
            } else {
                orientation = Configuration.ORIENTATION_LANDSCAPE;
            }
        }
        return orientation;
    }

        private final int REQUEST_PERMISSIONS = 4;

        public void checkPer () {

        if (ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.ACCESS_COARSE_LOCATION) +
                ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.ACCESS_FINE_LOCATION +
                        ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.WRITE_EXTERNAL_STORAGE) +
                        ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.READ_EXTERNAL_STORAGE) +
                        ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.BLUETOOTH_CONNECT) +
                        ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.BLUETOOTH_SCAN)) != PackageManager.PERMISSION_GRANTED) {

            if (ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.ACCESS_COARSE_LOCATION) ||
                    ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.ACCESS_FINE_LOCATION) ||
                    ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.WRITE_EXTERNAL_STORAGE) ||
                    ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.READ_EXTERNAL_STORAGE) ||
                    ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.BLUETOOTH_CONNECT) ||
                    ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.BLUETOOTH_SCAN)
            ) {
                //below s

                ActivityCompat.requestPermissions(FetalDoppler1.this,
                        permission,
                        REQUEST_PERMISSIONS);

            } else {

                ActivityCompat.requestPermissions(FetalDoppler1.this,
                        permission,
                        REQUEST_PERMISSIONS);
            }
        } else {
            connectWithDevice();
        }
    }



    public void checkPer1() {

        if (ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.ACCESS_COARSE_LOCATION) +
                ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.ACCESS_FINE_LOCATION) +
                ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.BLUETOOTH_CONNECT) +
                ContextCompat.checkSelfPermission(FetalDoppler1.this, Manifest.permission.BLUETOOTH_SCAN) != PackageManager.PERMISSION_GRANTED) {

            if (ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.ACCESS_COARSE_LOCATION) ||
                    ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.ACCESS_FINE_LOCATION) ||
                    ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.BLUETOOTH_CONNECT) ||
                    ActivityCompat.shouldShowRequestPermissionRationale(FetalDoppler1.this, Manifest.permission.BLUETOOTH_SCAN)
            ) {
                ActivityCompat.requestPermissions(FetalDoppler1.this,
                        permission,
                        REQUEST_PERMISSIONS);
            } else {
                ActivityCompat.requestPermissions(FetalDoppler1.this,
                        permission,
                        REQUEST_PERMISSIONS);
            }
        } else {
            connectWithDevice();
        }
    }
        @Override
        public void onMessageReceived (String Data){
        if (Data.equalsIgnoreCase("save")) {
            save.callOnClick();

        } else if (Data.equalsIgnoreCase("discard") || Data.equalsIgnoreCase("ble_close")) {
            d.sendData("clicked_discard");
            Intent intent = new Intent();
            Log.d(TAG, "onMessageReceived: " + packageName);
            intent.setComponent(new ComponentName(packageName, className));
            startActivity(intent);
            finish();


        } else if (Data.equalsIgnoreCase("record")) {
            stop.callOnClick();
        }

    }

        @Override
        protected void onDestroy () {
        super.onDestroy();
        d.sendData("complete");
        handler = null;
        measureParameter = null;
        d.unBindService();
    }

    @Override
    public void onRequestPermissionsResult(int requestCode, @NonNull String[] permissions,
                                           @NonNull int[] grantResults) {
        super.onRequestPermissionsResult(requestCode, permissions, grantResults);

        if (requestCode == REQUEST_PERMISSIONS) {
            if (grantResults.length > 0) {


                boolean ACCESS_COARSE_LOCATION = grantResults[0] == PackageManager.PERMISSION_GRANTED;
                boolean ACCESS_FINE_LOCATION = grantResults[1] == PackageManager.PERMISSION_GRANTED;

                if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
                    boolean BLUETOOTH_CONNECT = grantResults[2] == PackageManager.PERMISSION_GRANTED;
                    boolean BLUETOOTH_SCAN = grantResults[3] == PackageManager.PERMISSION_GRANTED;

                    if (ACCESS_COARSE_LOCATION && ACCESS_FINE_LOCATION && BLUETOOTH_CONNECT && BLUETOOTH_SCAN) {
                        connectWithDevice();
                    } else {
                        Log.d(TAG, "onRequestPermissionsResult: toast 1 ");
                        Toast.makeText(this, getResources().getString(R.string.please_give_all_the_permission), Toast.LENGTH_SHORT).show();
                        ActivityCompat.requestPermissions(FetalDoppler1.this,
                                permissions,
                                REQUEST_PERMISSIONS);
                    }
                } else if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.S) {
                    boolean WRITE_EXTERNAL_STORAGE = grantResults[2] == PackageManager.PERMISSION_GRANTED;
                    boolean READ_EXTERNAL_STORAGE = grantResults[3] == PackageManager.PERMISSION_GRANTED;
                    boolean BLUETOOTH_CONNECT = grantResults[4] == PackageManager.PERMISSION_GRANTED;
                    boolean BLUETOOTH_SCAN = grantResults[5] == PackageManager.PERMISSION_GRANTED;

                    if (ACCESS_COARSE_LOCATION && ACCESS_FINE_LOCATION && WRITE_EXTERNAL_STORAGE &&
                            READ_EXTERNAL_STORAGE && BLUETOOTH_CONNECT && BLUETOOTH_SCAN) {
                        connectWithDevice();
                    } else {
                        Log.d(TAG, "onRequestPermissionsResult: toast 2");
                        Toast.makeText(this, getResources().getString(R.string.please_give_all_the_permission), Toast.LENGTH_SHORT).show();
                        ActivityCompat.requestPermissions(FetalDoppler1.this,
                                permissions,
                                REQUEST_PERMISSIONS);
                    }
                } else {
                    boolean WRITE_EXTERNAL_STORAGE = grantResults[2] == PackageManager.PERMISSION_GRANTED;
                    boolean READ_EXTERNAL_STORAGE = grantResults[3] == PackageManager.PERMISSION_GRANTED;

                    if (ACCESS_COARSE_LOCATION && ACCESS_FINE_LOCATION && WRITE_EXTERNAL_STORAGE && READ_EXTERNAL_STORAGE) {
                        connectWithDevice();
                    } else {
                        Log.d(TAG, "onRequestPermissionsResult: toast 3");
                        Toast.makeText(this, getResources().getString(R.string.please_give_all_the_permission), Toast.LENGTH_SHORT).show();
                        ActivityCompat.requestPermissions(FetalDoppler1.this,
                                permissions,
                                REQUEST_PERMISSIONS);
                    }
                }
            }
        }
    }

        void connectWithDevice () {
        DateFormat df = new SimpleDateFormat("h_mm_ss");
        String date = df.format(Calendar.getInstance().getTime());
        long endTime = System.currentTimeMillis();
        long totalTime = endTime - startTime;
        Log.d("TAG", "Running time 2: " + totalTime + " milliseconds");

        if (pid != null) {

            id = pid + date;
            Logger.d("Time detail", "" + id);
        } else {
            id = getDateTime();
        }

        // SensorName should be null if you want to use old device("iFM10B") flow. else pass sensor name. sensorName is Device Bluetooth name like.
        measureParameter = new BluetoothMeasureParameter(FetalDoppler1.this, DeviceScanActivity.USE_SENSOR, id, sensorName, useBLEService);

        measureParameter.scanAndConnect();

    }


}