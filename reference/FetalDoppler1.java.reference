        @Override
        public void onBackPressed () {


        if (!packageName.equalsIgnoreCase("com.nscpl.test")) {

            if (select) {
                measureParameter.disconnect();


                long startTimeMillis = System.currentTimeMillis();
                SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss", Locale.US);
                sdf.setTimeZone(TimeZone.getTimeZone("UTC")); // Convert to UTC
                endtime = sdf.format(new Date(startTimeMillis));

                Log.d(TAG, "onBackPressed: fetal "+starttime+" "+endtime);

                Logger.d(TAG, "debugFeetaldooplerpackageName, packageNAme = " + packageName + "\n Class name = " + className);
                Log.d(TAG, "onBackPressed: packageNAme = " + packageName + "\n Class name = " + className);
                Logger.d(TAG, "debugFeetaldoplerhartrate, FETAL_DOPPLER_HERAT_RATE  = " + FETAL_DOPPLER_HERAT_RATE + "\nfinalHeartRate  = " + finalHeartRate);
                Logger.d(TAG, "debugFeetaldoplerfile, FETAL_FILE_NAME  = " + FETAL_FILE_NAME + "\nfile  = " + file.toString());
                Uri contentUri = FileProvider.getUriForFile(FetalDoppler1.this, "com.neurosynaptic.nova_iassist.fileprovider", file);
                Intent sharingIntent = new Intent(Intent.ACTION_SEND);
                sharingIntent.setType("text/*");
                sharingIntent.putExtra(Intent.EXTRA_STREAM, contentUri);
                sharingIntent.putExtra(FETAL_DOPPLER_HERAT_RATE, finalHeartRate);
                sharingIntent.putExtra(DeviceScanActivity.SENSOR_TYPE, DeviceScanActivity.FETAL_DOPPLER);
                sharingIntent.setComponent(new ComponentName(packageName, className));
                sharingIntent.setFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);
                sharingIntent.setFlags(Intent.FLAG_GRANT_WRITE_URI_PERMISSION);

                sharingIntent.putExtra("starttime", starttime);
                sharingIntent.putExtra("endtime", endtime);

                startActivity(sharingIntent);
                Toast.makeText(FetalDoppler1.this, getString(R.string.saved_successfully), Toast.LENGTH_SHORT).show();

            } else {
                Toast.makeText(FetalDoppler1.this, getResources().getString(R.string.save_or_discard), Toast.LENGTH_LONG).show();
            }

        } else {
            measureParameter.disconnect();
            super.onBackPressed();
        }

    }

        boolean found = false;

        @Override
        public void fetalDopplerReadingReceived ( int heartRate, int tocoWave,
        int afmWave, int status1, int status2, byte[] dataArr, boolean b){


        mHeartRate = Integer.toString(heartRate);
        fetal_heart_rate.setText(mHeartRate);

        Logger.d(TAG, "debugHartrates, hartrate : " + mHeartRate);

        //  byte[] decodedBytes = Base64.decode(encodedString, Base64.NO_WRAP);

        if (heartRate > 0) {

            if (!found) {
                display_content.setText(getResources().getString(R.string.heart_rate_found));
                d.sendData("done_fetal_found");
                found = true;
            }

            if (count == 1) {
                stop.setVisibility(View.INVISIBLE);
            } else {
                stop.setVisibility(View.VISIBLE);
            }
        }
    }

        @Override
        public void fetalDopplerframeRecieved ( byte[] data, boolean b){
        try {
            String encodedString = new String(data, "UTF-8");
            Log.d(TAG, "fetalDopplerframeRecieved: Encoded String" + encodedString);
            String s1 = "data_fetal_set_a_" + mHeartRate + "_" + encodedString;
            d.sendData(s1);
        } catch (Exception e) {

        }
    }

        @Override
        public void onNotConnected (String message){

        Toast.makeText(FetalDoppler1.this, message, Toast.LENGTH_LONG).show();

        BluetoothAdapter mBluetoothAdapter = BluetoothAdapter.getDefaultAdapter();

        if (!mBluetoothAdapter.isEnabled()) {
            handler.removeCallbacksAndMessages(null);
            if(measureParameter!=null)
            measureParameter.stop();
            progress.setMax(0);
            progress.setProgress(0);
            record.setText(getResources().getString(R.string.bluetooth_turned_off));
            d.sendData("done_fetal_off");
        } else {
            if (message.equalsIgnoreCase("Device connection was lost")) {
                handler.removeCallbacksAndMessages(null);
                if(measureParameter!=null)
                measureParameter.stop();
                progress.setMax(0);
                progress.setProgress(0);
                d.sendData("done_fetal_lost");
                record.setText(getResources().getString(R.string.device_connection_was_lost));
            }
        }


    }

        public void setMessage (String mess){

        record.setText(mess);
    }

        @Override
        public void onConnecting () {


    }

        @Override
        public void onConnected (String deviceName){

        long endTime = System.currentTimeMillis();
        long totalTime = endTime - startTime;
        Log.d("TAG", "Running time : " + totalTime + " milliseconds");

        Toast.makeText(FetalDoppler1.this, getResources().getString(R.string.connected_to) + deviceName, Toast.LENGTH_SHORT).show();
        if (useBLEService) {
            d.sendData("ble_sensorconnected_fetosense_105");
        } else {
            d.sendData("ble_sensorconnected_FETALDoppler_70");
        }

            startTimer();
        }

    private void startTimer() {
        try {
            new CountDownTimer(30000, 1000) {

                @Override
                public void onTick(long millisUntilFinished) {
                    //mTextField.setText("seconds remaining: " + millisUntilFinished / 1000);
                    Logger.d("display the timer", "" + "seconds remaining: " + millisUntilFinished / 1000);

                    if(measureParameter!=null)
                      measureParameter.startReading();
                    progressDisplay();


                    try {

                        Logger.d("display", "" + record.length());

                        if (record != null && record.getText().toString().equalsIgnoreCase("Device connection was lost.Re-connect it again") || record.getText().toString().equalsIgnoreCase("Bluetooth turned off! Please take reading again")) {
                            Logger.d("display the connection", "" + record.getText().toString());
                            cancel();
                            progress.setMax(0);
                            progress.setProgress(0);
                        }
                    } catch (Exception e) {
                        e.printStackTrace();
                    }
                }

                @Override
                public void onFinish() {

               if(handler!=null ) {
                   Logger.d("display", "done");

                   handler.removeCallbacksAndMessages(null);
               }
                 if(measureParameter!=null)
                      measureParameter.stop();
                    progress.setMax(0);
                    progress.setProgress(0);
                    setMessage(getResources().getString(R.string.save_or_discard));
                    d.sendData("done_fetal_complete");
                    stop.setVisibility(View.INVISIBLE);
                    //  start.setVisibility(View.INVISIBLE);
                }
            }.start();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

