    CountDownTimer timer = new CountDownTimer(totalSeconds * 1000, intervalSeconds * 1000) {

        public void onTick(long millisUntilFinished) {
            Logger.d("seconds elapsed: ", "" + (totalSeconds * 1000 - millisUntilFinished) / 1000);
            if(measureParameter!=null);
            measureParameter.startReading();
            startTime2 = System.currentTimeMillis();
            progressDisplay();

        }


        public void onFinish() {
            Logger.d("done!", "Time's up!");
            Logger.d("display", "done");
            handler.removeCallbacksAndMessages(null);
            measureParameter.stop();

            long endTime2 = System.currentTimeMillis();

            long totalTime = endTime2 - startTime2;

            Log.d("TAG", "Running time 2: " + totalTime + " milliseconds");

            progress.setMax(0);
            progress.setProgress(0);
            setMessage(getResources().getString(R.string.save_or_discard));
            stop.setVisibility(View.INVISIBLE);
        }

    };
    public static final String TAG = FetalDoppler1.class.getSimpleName();

    static public boolean deleteDirectory(File path) {

        if (path.exists()) {
            File[] files = path.listFiles();
            for (int i = 0; i < files.length; i++) {
                if (files[i].isDirectory()) {
                    deleteDirectory(files[i]);
                } else {
                    files[i].delete();
                }
            }
        }
        return (path.delete());
    }

