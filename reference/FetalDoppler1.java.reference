//                File fil = new File(Environment.getExternalStorageDirectory().toString() + File.separator + "Remedi" + File.separator + "Fetal_Sound" + File.separator);
//                file = new File(fil, "Fetal_reading_" + id + ".txt");

                // --------New File creation android 10-------------


//                File externalDirectory = getExternalFilesDir(null);
//                Logger.d(TAG, "filePathDebug, (save): externalDirectory >> " + externalDirectory.getPath());
//
//                File directoryFile = new File(externalDirectory, "Remedi/Fetal_Sound/");
//                if (directoryFile.exists()) {
//                    Logger.d(TAG, "filePathDebug, (save): directoryFile already exist..");
//                } else {
//                    directoryFile.mkdirs();
//                    if (directoryFile.isDirectory()) {
//                        Logger.d(TAG, "filePathDebug, (save): directoryFile created successfully...");
//                    } else
//                        Logger.e(TAG, "filePathDebug, (save): couldn't create directoryFile!!!");
//                }
//
//                file = new File(directoryFile, "Fetal_reading_" + id + ".txt");
//                Logger.d(TAG, "filePathDebug, (save): file: " + file);
//                // storage/emulated/0/com.ne--ic.iAssist/files/Remedi/Fetal_sound/Fetal_reading_123.txt
//                // -------------------------------------------------

                saveFetalReading();

                if (file.exists()) {
                    Logger.d("path", "" + file.toString());
                } else {
                    Logger.d("path", "null");
                }
                finalHeartRate = mHeartRate;
                Logger.d(TAG, "debugFinalHarrate, hartrate " + finalHeartRate);
                if (finalHeartRate.length() > 0) {
                    Toast.makeText(FetalDoppler1.this, getResources().getString(R.string.saved_successfully), Toast.LENGTH_LONG).show();

                    if (d != null)
                        d.sendData("clicked_save");

                }
                select = true;
                onBackPressed();
