                    Log.d(TAG, "onClick: filePathDebug, (discard): externalDir >>" + externalDir.getPath());
                    Logger.d(TAG, "filePathDebug, (discard): externalDir >> " + externalDir.getPath());
                    File dirFile = new File(externalDir, "Remedi/Fetal_Sound/");
                    file = new File(dirFile, "Fetal_reading_" + id + ".txt");
                    Logger.d(TAG, "filePathDebug, (discard): file >> " + file);
                    // -----------------

                    if (file.exists()) {
                        Log.d(TAG, "onClick: details");
                        boolean del = file.delete();
                        if (del) {
                            if (d != null)
                                d.sendData("clicked_discard");

                            Toast.makeText(FetalDoppler1.this, getResources().getString(R.string.deleted), Toast.LENGTH_SHORT).show();
                        }

                    } else {
                        if (d != null)
                            d.sendData("clicked_discard");

                    }
                    finish();
                } catch (Exception e) {
                    e.printStackTrace();
                }
                break;
        }
    }

    private void saveFetalReading() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU) {
            // Use app-specific directory for Android 13+
            File externalDirectory = getExternalFilesDir(null);
            File directoryFile = new File(externalDirectory, "Remedi/Fetal_Sound/");
            if (!directoryFile.exists()) {
                directoryFile.mkdirs();
            }
            file = new File(directoryFile, "Fetal_reading_" + id + ".txt");
        } else {
            // Use existing storage method for older versions
            File externalDirectory = getExternalFilesDir(null);
            File directoryFile = new File(externalDirectory, "Remedi/Fetal_Sound/");
            if (!directoryFile.exists()) {
                directoryFile.mkdirs();
            }
            file = new File(directoryFile, "Fetal_reading_" + id + ".txt");
        }
    }


